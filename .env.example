# SmartVenue — Environment Variables Template
# Copy this file to .env and fill in your keys

# Google Cloud & Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini AI Configuration
VITE_GEMINI_KEY=your_gemini_api_key_here

# Google Maps Configuration
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# Application Settings
VITE_APP_MODE=simulation # Use 'live' for real-time Firestore sync
VITE_DEFAULT_ROLE=attendee # Use 'operator' for administrative access in simulation
